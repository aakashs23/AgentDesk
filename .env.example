# Copy to .env and fill in. Never commit .env.

APP_ENV=development

# Postgres — credentials for docker-compose. Keep DATABASE_URL in sync when changed.
# For production, use strong passwords and never commit .env.
POSTGRES_USER=agentdesk
POSTGRES_PASSWORD=
POSTGRES_DB=agentdesk
DATABASE_URL=postgresql+asyncpg://agentdesk@localhost:5432/agentdesk

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# LLM provider — resolved in Phase 5: Gemini 2.5 Flash + gemini-embedding-001 (1536 dims)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Only needed if an external vector store is chosen over pgvector-only (Phase 5 decision)
VECTOR_DB_API_KEY=

# SMTP (notifications, Phase 7)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Encrypts stored webhook secrets (Backend Schema doc 05, Section 8)
# generate with: openssl rand -hex 32
WEBHOOK_SECRET_ENCRYPTION_KEY=

# Future — Slack notification channel (PRD nice-to-have)
SLACK_WEBHOOK_URL=

# Frontend
VITE_API_URL=http://localhost:8000
